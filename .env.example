LLM_API_URL=https://coding.caolele.top/v1/chat/completions
LLM_API_KEY=replace-me
LLM_MODEL=glm-4.7

MX_APIKEY=replace-me

# 免费实时源：东财 push2。主域偶发断连时优先使用 delay 域。
EASTMONEY_PUSH2_HOSTS=https://push2delay.eastmoney.com,https://push2.eastmoney.com
EASTMONEY_PAGE_SIZE=100
EASTMONEY_MAX_PAGES=80
EASTMONEY_TIMEOUT_MS=15000
EASTMONEY_RETRIES=2

# 免费天气风险源：Open-Meteo，无需 key。格式：城市,纬度,经度;城市,纬度,经度
WEATHER_LOCATIONS=北京,39.9042,116.4074;上海,31.2304,121.4737;广州,23.1291,113.2644;深圳,22.5431,114.0579;郑州,34.7466,113.6254;乌鲁木齐,43.8256,87.6168
WEATHER_TIMEOUT_MS=10000

# 历史回测数据源：
# 推荐生产回测使用 tushare；未配置 token 时 CLI 会退回 eastmoney fallback 仅用于 smoke test。
HISTORY_PROVIDER=tushare
# 默认官方地址；如走 Tushare 代理，填代理根地址，例如 http://x.x.x.x:port
TUSHARE_API_URL=http://api.tushare.pro
TUSHARE_TOKEN=replace-me
TUSHARE_MCP_URL=https://api.tushare.pro/mcp/?token=replace-me
TUSHARE_TIMEOUT_MS=20000

# 如后续安装 Python + baostock/akshare，可指定解释器路径。
HIST_PYTHON=C:\Path\To\python.exe

FEISHU_WEBHOOK_ENABLED=0
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/replace-me
FEISHU_APP_ID=replace-me
FEISHU_APP_SECRET=replace-me
FEISHU_CHAT_ID=replace-me

DAILY_SITE_URL=http://117.72.58.55/daily/
